{
  "ConnectionStrings": {
    "DefaultConnection": "Host={HOST};Port=5432;Database={DB_NAME};Username={USER};Password={PASSWORD}"
  },
  "JwtSettings": {
    "SecretKey": "${JWT_SECRET_KEY}",
    "Issuer": "Kumashaurma",
    "Audience": "KumashaurmaClient",
    "ExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 7
  }
}
